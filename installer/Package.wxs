<?xml version="1.0" encoding="utf-8"?>
<!--
    WiX v4 / v5 Package 定义
    使用方式：
        wix build Package.wxs -d PublishDir=<发布目录路径>\ -o OneFindSetup.msi -arch x64
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="OneFind"
    Manufacturer="OneFind Project"
    Version="1.0.0"
    UpgradeCode="3F8A7B9C-1D2E-4F56-8A9B-0C1D2E3F4A5B"
    Scope="perMachine">

    <SummaryInformation Description="OneNote 全文搜索工具" />

    <!-- 安装更新时自动卸载旧版本 -->
    <MajorUpgrade DowngradeErrorMessage="已安装了更新版本，无法降级安装。" />

    <!-- 将所有文件打包进 MSI（无需外部 .cab） -->
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="OneFind" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcutComp" />
      <ComponentRef Id="DesktopShortcutComp" />
    </Feature>

  </Package>

  <!-- ── 目录结构 ─────────────────────────────────────── -->
  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">

      <!-- 程序安装目录：C:\Program Files\OneFind\ -->
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="OneFind" />
      </Directory>

      <!-- 开始菜单 -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="OneFind" />
      </Directory>

      <!-- 桌面 -->
      <Directory Id="DesktopFolder" />

    </Directory>
  </Fragment>

  <!-- ── 应用程序文件 ──────────────────────────────────── -->
  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <!--
          PublishDir 变量由构建脚本传入，例如：
          wix build ... -d PublishDir=D:\...\publish\
          单文件发布时此处只有一个 .exe
      -->
      <Component Id="MainExe" Guid="*">
        <File Id="OneFindExe"
              Source="$(var.PublishDir)OneFind.exe"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- ── 开始菜单快捷方式 ──────────────────────────────── -->
  <Fragment>
    <DirectoryRef Id="AppMenuFolder">
      <Component Id="StartMenuShortcutComp" Guid="*">
        <Shortcut Id="StartMenuLink"
                  Name="OneFind"
                  Description="OneNote 全文搜索"
                  Target="[INSTALLFOLDER]OneFind.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <!-- 卸载时清理开始菜单文件夹 -->
        <RemoveFolder Id="RemoveAppMenuFolder"
                      Directory="AppMenuFolder"
                      On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\OneFind"
                       Name="StartMenuInstalled"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>

  <!-- ── 桌面快捷方式 ──────────────────────────────────── -->
  <Fragment>
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcutComp" Guid="*">
        <Shortcut Id="DesktopLink"
                  Name="OneFind"
                  Description="OneNote 全文搜索"
                  Target="[INSTALLFOLDER]OneFind.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\OneFind"
                       Name="DesktopInstalled"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>

</Wix>
