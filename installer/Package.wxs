<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="OneFinder"
    Manufacturer="OneFinder Project"
    Version="1.0.0"
    UpgradeCode="3F8A7B9C-1D2E-4F56-8A9B-0C1D2E3F4A5B"
    Scope="perMachine">

    <SummaryInformation Description="OneFinder - OneNote full-text search" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!--
      Check for .NET 8 Desktop Runtime (x64).
      OneFinder.exe is published as framework-dependent, so the runtime must be present.
      The registry key is written by the .NET installer under HKLM.
    -->
    <Property Id="DOTNET8_DESKTOP_INSTALLED">
      <RegistrySearch Id="SearchDotNet8Desktop"
        Root="HKLM"
        Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedfx\Microsoft.WindowsDesktop.App"
        Name="8.0.0"
        Type="raw" />
    </Property>
    <Launch Condition="Installed OR DOTNET8_DESKTOP_INSTALLED"
            Message="OneFinder requires the .NET 8 Desktop Runtime (x64). Please download and install it from https://aka.ms/dotnet8-desktop-runtime-win-x64 and then run this installer again." />

    <Feature Id="Main" Title="OneFinder" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="AddinFiles" />
      <ComponentGroupRef Id="ComRegistry" />
      <ComponentRef Id="StartMenuShortcutComp" />
      <ComponentRef Id="DesktopShortcutComp" />
    </Feature>

  </Package>

  <!-- Directory layout (WiX v5 style using StandardDirectory) -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OneFinder" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="OneFinder" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
  </Fragment>

  <!-- Main app files (.NET 8 framework-dependent publish output) -->
  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component Id="MainExe" Guid="*">
        <File Id="OneFinderExe"
              Source="$(var.PublishDir)OneFinder.exe"
              KeyPath="yes" />
      </Component>
      <Component Id="MainDll" Guid="*">
        <File Id="OneFinderDll"
              Source="$(var.PublishDir)OneFinder.dll"
              KeyPath="yes" />
      </Component>
      <Component Id="RuntimeConfig" Guid="*">
        <File Id="OneFinderRuntimeConfig"
              Source="$(var.PublishDir)OneFinder.runtimeconfig.json"
              KeyPath="yes" />
      </Component>
      <Component Id="DepsJson" Guid="*">
        <File Id="OneFinderDepsJson"
              Source="$(var.PublishDir)OneFinder.deps.json"
              KeyPath="yes" />
      </Component>
      <Component Id="OneNoteInterop" Guid="*">
        <File Id="OneNoteInteropDll"
              Source="$(var.PublishDir)Microsoft.Office.Interop.OneNote.dll"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- OneNote addin DLL (.NET Framework 4.8, loaded by OneNote via mscoree.dll) -->
  <Fragment>
    <ComponentGroup Id="AddinFiles" Directory="INSTALLFOLDER">
      <Component Id="AddinDll" Guid="*">
        <File Id="OneFinderAddinDll"
              Source="$(var.AddinDir)OneFinder.AddIn.dll"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!--
    COM registration + OneNote addin activation
    See: https://github.com/stevencohn/OneMore/blob/main/register-onemore.reg

    CLSID  : {6B29FC40-CA47-1067-B31D-00DD010662DA}
    ProgID : OneFinder.AddIn
    OneNote loads the addin at startup via LoadBehavior=3
  -->
  <Fragment>
    <ComponentGroup Id="ComRegistry" Directory="INSTALLFOLDER">

      <Component Id="Reg_ProgId" Guid="*">
        <RegistryKey Root="HKCR" Key="OneFinder.AddIn">
          <RegistryValue Type="string" Value="OneFinder.AddIn" />
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="OneFinder.AddIn\CLSID">
          <RegistryValue Type="string" Value="{6B29FC40-CA47-1067-B31D-00DD010662DA}" />
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="OneFinder.AddIn\CurVer">
          <RegistryValue Type="string" Value="OneFinder.AddIn.1" />
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="OneFinder.AddIn.1">
          <RegistryValue Type="string" Value="OneFinder.AddIn" />
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="OneFinder.AddIn.1\CLSID">
          <RegistryValue Type="string" Value="{6B29FC40-CA47-1067-B31D-00DD010662DA}" />
        </RegistryKey>
      </Component>

      <Component Id="Reg_AppId" Guid="*">
        <RegistryKey Root="HKCR" Key="AppID\{6B29FC40-CA47-1067-B31D-00DD010662DA}">
          <RegistryValue Type="string" Value="" />
          <RegistryValue Name="DllSurrogate" Type="string" Value="" />
        </RegistryKey>
      </Component>

      <Component Id="Reg_Clsid" Guid="*">
        <!-- CLSID entry -->
        <RegistryKey Root="HKCR" Key="CLSID\{6B29FC40-CA47-1067-B31D-00DD010662DA}">
          <RegistryValue Type="string" Value="OneFinder.AddIn" />
          <RegistryValue Name="AppID" Type="string" Value="{6B29FC40-CA47-1067-B31D-00DD010662DA}" />
        </RegistryKey>
        <!-- InprocServer32: CLR 4.0 loads the .NET 4.8 assembly via mscoree.dll -->
        <RegistryKey Root="HKCR" Key="CLSID\{6B29FC40-CA47-1067-B31D-00DD010662DA}\InprocServer32">
          <RegistryValue Type="string"  Value="mscoree.dll" />
          <RegistryValue Name="ThreadingModel" Type="string" Value="Both" />
          <RegistryValue Name="Class"          Type="string" Value="OneFinder.AddIn.AddIn" />
          <RegistryValue Name="Assembly"       Type="string" Value="OneFinder.AddIn, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" />
          <RegistryValue Name="RuntimeVersion" Type="string" Value="v4.0.30319" />
          <RegistryValue Name="CodeBase"       Type="string" Value="file:///[INSTALLFOLDER]OneFinder.AddIn.dll" />
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="CLSID\{6B29FC40-CA47-1067-B31D-00DD010662DA}\InprocServer32\1.0.0.0">
          <RegistryValue Name="Class"          Type="string" Value="OneFinder.AddIn.AddIn" />
          <RegistryValue Name="Assembly"       Type="string" Value="OneFinder.AddIn, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" />
          <RegistryValue Name="RuntimeVersion" Type="string" Value="v4.0.30319" />
          <RegistryValue Name="CodeBase"       Type="string" Value="file:///[INSTALLFOLDER]OneFinder.AddIn.dll" />
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="CLSID\{6B29FC40-CA47-1067-B31D-00DD010662DA}\ProgID">
          <RegistryValue Type="string" Value="OneFinder.AddIn" />
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="CLSID\{6B29FC40-CA47-1067-B31D-00DD010662DA}\VersionIndependentProgID">
          <RegistryValue Type="string" Value="OneFinder.AddIn" />
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="CLSID\{6B29FC40-CA47-1067-B31D-00DD010662DA}\Programmable">
          <RegistryValue Type="string" Value="" />
        </RegistryKey>
        <!-- .NET component category {62C8FE65-4EBB-45E7-B440-6E39B2CDBF29} -->
        <RegistryKey Root="HKCR" Key="CLSID\{6B29FC40-CA47-1067-B31D-00DD010662DA}\Implemented Categories\{62C8FE65-4EBB-45E7-B440-6E39B2CDBF29}">
          <RegistryValue Type="string" Value="" />
        </RegistryKey>
      </Component>

      <!-- Tell OneNote to load this addin at startup (LoadBehavior=3) -->
      <Component Id="Reg_OneNoteAddin" Guid="*">
        <RegistryKey Root="HKCU" Key="SOFTWARE\Microsoft\Office\OneNote\AddIns\OneFinder.AddIn">
          <RegistryValue Name="LoadBehavior"    Type="integer" Value="3" KeyPath="yes" />
          <RegistryValue Name="FriendlyName"    Type="string"  Value="OneFinder" />
          <RegistryValue Name="Description"     Type="string"  Value="OneFinder - OneNote full-text search" />
          <RegistryValue Name="CommandLineSafe" Type="integer" Value="0" />
        </RegistryKey>
        <!--
          防止 Office Resiliency 机制在 OneNote 意外崩溃后自动禁用本 AddIn。
          没有此键时，Office 检测到启动失败会将 LoadBehavior 改为 2 并记入
          Resiliency\StartupItems，导致后续 OneNote 启动时 AddIn 反复加载失败。
        -->
        <RegistryKey Root="HKCU" Key="SOFTWARE\Microsoft\Office\16.0\OneNote\Resiliency\DoNotDisableAddinList">
          <RegistryValue Name="OneFinder.AddIn" Type="integer" Value="1" />
        </RegistryKey>
        <!--
          安装/升级时主动清除 Resiliency 机制留下的禁用记录，确保 LoadBehavior
          被 Office 意外改为 2 后重装即可恢复，而无需用户手动修改注册表。
        -->
        <RemoveRegistryValue Root="HKCU"
          Key="SOFTWARE\Microsoft\Office\16.0\OneNote\Resiliency\StartupItems"
          Name="OneFinder.AddIn" />
      </Component>

      <!--
        清理旧版名称 "OneFind.AddIn" 遗留的 AddIn 注册键（项目曾用名）。
        若残留此键，OneNote 会同时尝试加载两个 AddIn，可能导致按钮重复或加载失败。
      -->
      <Component Id="Reg_CleanupOldAddin" Guid="*">
        <RemoveRegistryKey Root="HKCU"
          Key="SOFTWARE\Microsoft\Office\OneNote\AddIns\OneFind.AddIn"
          Action="removeOnInstall" />
        <RegistryValue Root="HKCU" Key="Software\OneFinder"
                       Name="OldAddinCleaned" Type="integer" Value="1" KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- Start menu shortcut -->
  <Fragment>
    <DirectoryRef Id="AppMenuFolder">
      <Component Id="StartMenuShortcutComp" Guid="*">
        <Shortcut Id="StartMenuLink"
                  Name="OneFinder"
                  Description="OneNote full-text search"
                  Target="[INSTALLFOLDER]OneFinder.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\OneFinder"
                       Name="StartMenuInstalled" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>

  <!-- Desktop shortcut -->
  <Fragment>
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComp" Guid="*">
        <Shortcut Id="DesktopLink"
                  Name="OneFinder"
                  Description="OneNote full-text search"
                  Target="[INSTALLFOLDER]OneFinder.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\OneFinder"
                       Name="DesktopInstalled" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>
  </Fragment>

</Wix>